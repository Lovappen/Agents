# ~/.openclaw/skills/.env — shared skill env (loaded FIRST)
# Per-agent values in <workspace>/skills/.env override these.
#
# 安装器会交互问你每一项。所有值留空即代表「不启用」对应能力。
# DO NOT commit this file with real keys.

# ───── MiniMax (TTS + music/sing) — 国内版 ─────
# 去 https://platform.minimaxi.com 申请 key
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# ───── 火山引擎 TTS（可选备选） ─────
# https://console.volcengine.com/speech/new
VOLCENGINE_API_KEY=
VOLCENGINE_RESOURCE_ID=seed-tts-1.0

# ───── 默认 TTS 音色/语速（可选） ─────
VOICE_DEFAULT_MINIMAX=female-tianmei
VOICE_DEFAULT_VOLCENGINE=zh_female_shuangkuaisisi_moon_bigtts
VOICE_DEFAULT_SPEED=1.0

# ───── selfie 图像生成 ─────
# fal.ai (推荐，同步，支持参考图)：https://fal.ai/dashboard/keys
FAL_KEY=
# kie.ai (备选，异步)：https://kie.ai
KIE_API_KEY=

# ───── openclaw gateway（可选） ─────
OPENCLAW_GATEWAY_TOKEN=

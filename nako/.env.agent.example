# <workspace>/skills/.env — per-agent env (loaded LAST, overrides shared)
#
# 这里放 agent 专属的凭据，通常只有飞书 App 和角色标识。
# DO NOT commit this file with real keys.

# ───── 飞书 App 凭据（每个 agent 应有独立的飞书机器人） ─────
# 建应用：https://open.feishu.cn
# 详见 docs/feishu-setup.md
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ───── 角色视觉标识（selfie 会用） ─────
# 参考图 URL（角色相貌一致性用）— 填一张你希望 selfie 保持一致的图片链接
SELFIE_REFERENCE_IMAGE=
# 角色文字描述（生成自拍时会拼进 prompt）
SELFIE_CHARACTER_DESC=野木奈子，19岁人类美少女，红瞳，金色及肩发，战斗女仆装
